<div class="section">
  <div class="container" style="min-height: 80vh; display: flex; align-items: center; justify-content: center;">
    <div class="glass" style="max-width: 600px; width: 100%; text-align: center; padding: 60px 40px; border-radius: 24px; position: relative; overflow: hidden;">

      <!-- Decorative background elements -->
      <div style="position: absolute; top: -50px; left: -50px; font-size: 200px; color: rgba(122, 158, 126, 0.05); z-index: 0; transform: rotate(-15deg);">
        <i class="fas fa-leaf"></i>
      </div>
      <div style="position: absolute; bottom: -50px; right: -50px; font-size: 200px; color: rgba(122, 158, 126, 0.05); z-index: 0; transform: rotate(15deg);">
        <i class="fas fa-lemon"></i>
      </div>

      <div style="position: relative; z-index: 1;">
        <div style="width: 120px; height: 120px; background: linear-gradient(135deg, rgba(232, 197, 71, 0.2), rgba(232, 197, 71, 0.1)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 30px; border: 2px dashed rgba(232, 197, 71, 0.5);">
          <i class="fas fa-ghost" style="font-size: 60px; color: #e8c547; animation: float 3s ease-in-out infinite;"></i>
        </div>

        <h1 style="font-size: 80px; font-family: 'Playfair Display', serif; line-height: 1; margin-bottom: 10px; background: linear-gradient(to right, var(--cream), var(--sage-green)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">404</h1>
        <h2 style="font-size: 28px; font-family: 'Playfair Display', serif; margin-bottom: 20px;">Page Not Found</h2>

        <p style="font-size: 16px; color: rgba(245, 240, 232, 0.7); margin-bottom: 40px; line-height: 1.6;">
          <%= typeof message !== 'undefined' ? message : "Oops! The page you're looking for seems to have wandered off the farm. It might have been moved or doesn't exist anymore." %>
        </p>

        <% if (typeof error !== 'undefined' && Object.keys(error).length > 0) { %>
          <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 10px; margin-bottom: 30px; text-align: left; font-size: 12px; font-family: monospace; color: #ff7a8a; overflow-x: auto;">
            <%= error.stack %>
          </div>
        <% } %>

        <div style="display: flex; gap: 15px; justify-content: center;">
          <a href="/" class="btn btn-primary btn-lg">
            <i class="fas fa-home"></i> Back to Home
          </a>
          <a href="/shop" class="btn btn-secondary btn-lg">
            <i class="fas fa-shopping-basket"></i> Browse Shop
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }
</style>