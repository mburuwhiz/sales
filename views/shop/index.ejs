<div class="section">
  <div class="container">
    <div class="section-title">
      <h2>Our Products</h2>
      <p>Fresh, organic produce delivered to your doorstep</p>
    </div>

    <!-- Filters -->
    <div class="glass" style="padding: 20px; margin-bottom: 30px;">
      <form action="/shop" method="GET" style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
        <div style="flex: 1; min-width: 200px;">
          <label class="form-label">Category</label>
          <select name="category" class="form-input" onchange="this.form.submit()">
            <option value="all" <%= selectedCategory === 'all' ? 'selected' : '' %>>All Categories</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= selectedCategory === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <a href="/shop" class="btn btn-secondary">Reset Filters</a>
        </div>
      </form>
    </div>

    <!-- Products Grid -->
    <% if (products.length > 0) { %>
      <div class="grid grid-4">
        <% products.forEach(product => { %>
          <div class="product-card" onclick="openProductModal('<%= product._id %>')">
            <img src="<%= product.images[0] %>" alt="<%= product.name %>" class="product-image">
            <div class="product-info">
              <div class="product-category"><%= product.category %></div>
              <div class="product-name"><%= product.name %></div>
              <div class="product-price">KSH <%= product.price.toLocaleString() %></div>
              <div class="product-actions">
                <button class="btn btn-primary btn-sm" onclick="event.stopPropagation(); addToCart('<%= product._id %>')">
                  <i class="fas fa-plus"></i> Add
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div style="display: flex; justify-content: center; gap: 10px; margin-top: 40px;">
          <% if (currentPage > 1) { %>
            <a href="/shop?category=<%= selectedCategory %>&page=<%= currentPage - 1 %>" class="btn btn-secondary btn-sm">
              <i class="fas fa-chevron-left"></i>
            </a>
          <% } %>
          
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/shop?category=<%= selectedCategory %>&page=<%= i %>" 
               class="btn <%= currentPage === i ? 'btn-primary' : 'btn-secondary' %> btn-sm"
               style="min-width: 40px;">
              <%= i %>
            </a>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <a href="/shop?category=<%= selectedCategory %>&page=<%= currentPage + 1 %>" class="btn btn-secondary btn-sm">
              <i class="fas fa-chevron-right"></i>
            </a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div style="text-align: center; padding: 60px 20px;">
        <i class="fas fa-search" style="font-size: 60px; color: var(--sage-green); opacity: 0.5; margin-bottom: 20px;"></i>
        <h3>No products found</h3>
        <p style="color: rgba(245, 240, 232, 0.7);">Try adjusting your filters or browse all products.</p>
        <a href="/shop" class="btn btn-primary" style="margin-top: 20px;">View All Products</a>
      </div>
    <% } %>
  </div>
</div>

<!-- Product Modal -->
<div class="modal-overlay" id="productModal">
  <div class="modal-content glass" style="max-width: 800px; width: 90%; padding: 0; overflow: hidden;">
    <div id="modalContent"></div>
  </div>
</div>

<script>
  async function openProductModal(productId) {
    try {
      const response = await fetch(`/shop/product/${productId}`);
      const product = await response.json();

      const modal = document.getElementById('productModal');
      const content = document.getElementById('modalContent');

      content.innerHTML = `
        <div style="display: grid; grid-template-columns: 1fr 1fr;">
          <div style="background: rgba(0,0,0,0.2);">
            <img src="${product.images[0]}" alt="${product.name}" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
          <div style="padding: 40px; position: relative;">
            <button onclick="closeProductModal()" style="position: absolute; top: 15px; right: 15px; background: none; border: none; color: var(--cream); font-size: 24px; cursor: pointer;">
              <i class="fas fa-times"></i>
            </button>
            <div class="product-category">${product.category}</div>
            <h2 style="margin-bottom: 15px;">${product.name}</h2>
            <div class="product-price" style="font-size: 24px; margin-bottom: 20px;">KSH ${product.price.toLocaleString()}</div>
            <p style="color: rgba(245, 240, 232, 0.8); margin-bottom: 30px; line-height: 1.8;">${product.description}</p>
            
            <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
              <span>Quantity:</span>
              <div style="display: flex; align-items: center; gap: 10px;">
                <button class="qty-btn" onclick="decrementModalQty()">
                  <i class="fas fa-minus"></i>
                </button>
                <span id="modalQty" style="min-width: 30px; text-align: center;">1</span>
                <button class="qty-btn" onclick="incrementModalQty()">
                  <i class="fas fa-plus"></i>
                </button>
              </div>
            </div>

            <button class="btn btn-primary btn-lg" onclick="addModalToCart('${product._id}')" style="width: 100%;">
              <i class="fas fa-shopping-cart"></i> Add to Cart
            </button>

            <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--glass-border);">
              <div style="display: flex; gap: 20px; font-size: 13px; color: rgba(245, 240, 232, 0.6);">
                <span><i class="fas fa-check-circle" style="color: var(--sage-green);"></i> In Stock (${product.stockQty} available)</span>
                <span><i class="fas fa-truck" style="color: var(--sage-green);"></i> Free Delivery</span>
              </div>
            </div>
          </div>
        </div>
      `;

      modal.classList.add('active');
    } catch (error) {
      console.error('Failed to load product:', error);
      showToast('Failed to load product details', 'error');
    }
  }

  function closeProductModal() {
    document.getElementById('productModal').classList.remove('active');
  }

  let modalQuantity = 1;

  function incrementModalQty() {
    modalQuantity++;
    document.getElementById('modalQty').textContent = modalQuantity;
  }

  function decrementModalQty() {
    if (modalQuantity > 1) {
      modalQuantity--;
      document.getElementById('modalQty').textContent = modalQuantity;
    }
  }

  async function addModalToCart(productId) {
    await addToCart(productId, modalQuantity);
    closeProductModal();
    modalQuantity = 1;
  }

  document.getElementById('productModal').addEventListener('click', (e) => {
    if (e.target.id === 'productModal') {
      closeProductModal();
    }
  });
</script>
