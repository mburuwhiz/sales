<div class="section">
  <div class="container">
    <div class="glass" style="padding: 60px 40px; margin-top: 40px; border-radius: 24px;">

      <div style="text-align: center; margin-bottom: 50px;">
        <i class="fas fa-envelope-open-text" style="font-size: 50px; color: var(--sage-green); margin-bottom: 20px;"></i>
        <h1 style="font-size: 42px; font-family: 'Playfair Display', serif; margin-bottom: 15px;">Get in Touch</h1>
        <p style="color: rgba(245, 240, 232, 0.8); font-size: 18px; max-width: 600px; margin: 0 auto;">
          We'd love to hear from you. Whether you have a question about products, delivery, pricing, or anything else, our team is ready to answer all your questions.
        </p>
      </div>

      <div class="grid grid-2" style="gap: 50px;">
        <!-- Contact Information Side -->
        <div style="background: rgba(0,0,0,0.15); padding: 40px; border-radius: 20px; border: 1px solid var(--glass-border);">
          <h2 style="margin-bottom: 30px; font-family: 'Playfair Display', serif;">Contact Information</h2>

          <div style="display: flex; align-items: flex-start; gap: 20px; margin-bottom: 30px;">
            <div style="width: 50px; height: 50px; background: rgba(122, 158, 126, 0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <i class="fas fa-map-marker-alt" style="font-size: 20px; color: var(--sage-green);"></i>
            </div>
            <div>
              <h4 style="margin-bottom: 5px;">Our Store</h4>
              <p style="color: rgba(245, 240, 232, 0.7); font-size: 15px; line-height: 1.6;">123 Fresh Lane, Harvest Market<br>Nairobi, Kenya</p>
            </div>
          </div>

          <div style="display: flex; align-items: flex-start; gap: 20px; margin-bottom: 30px;">
            <div style="width: 50px; height: 50px; background: rgba(122, 158, 126, 0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <i class="fas fa-phone-alt" style="font-size: 20px; color: var(--sage-green);"></i>
            </div>
            <div>
              <h4 style="margin-bottom: 5px;">Call Us</h4>
              <p style="color: rgba(245, 240, 232, 0.7); font-size: 15px; line-height: 1.6;">Customer Service: 0113 323 234<br>Mon-Fri, 8:00am - 6:00pm</p>
            </div>
          </div>

          <div style="display: flex; align-items: flex-start; gap: 20px; margin-bottom: 30px;">
            <div style="width: 50px; height: 50px; background: rgba(122, 158, 126, 0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <i class="fas fa-envelope" style="font-size: 20px; color: var(--sage-green);"></i>
            </div>
            <div>
              <h4 style="margin-bottom: 5px;">Email Us</h4>
              <p style="color: rgba(245, 240, 232, 0.7); font-size: 15px; line-height: 1.6;">Support: support@freshharvest.app<br>Sales: orders@freshharvest.app</p>
            </div>
          </div>

          <div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid rgba(122, 158, 126, 0.2);">
            <h4 style="margin-bottom: 15px;">Follow Us</h4>
            <div style="display: flex; gap: 15px;">
              <a href="#" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--sage-green); font-size: 18px; transition: all 0.3s ease; border: 1px solid var(--glass-border);">
                <i class="fab fa-facebook-f"></i>
              </a>
              <a href="#" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--sage-green); font-size: 18px; transition: all 0.3s ease; border: 1px solid var(--glass-border);">
                <i class="fab fa-instagram"></i>
              </a>
              <a href="#" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--sage-green); font-size: 18px; transition: all 0.3s ease; border: 1px solid var(--glass-border);">
                <i class="fab fa-twitter"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Contact Form Side -->
        <div style="padding: 20px;">
          <h2 style="margin-bottom: 30px; font-family: 'Playfair Display', serif;">Send us a Message</h2>

          <form id="contactForm">
            <div class="form-group" style="margin-bottom: 25px;">
              <label class="form-label">Your Name</label>
              <div class="input-wrapper">
                <i class="fas fa-user"></i>
                <input type="text" name="name" class="form-input" style="padding-left: 48px;" placeholder="Enter your name" required>
              </div>
            </div>

            <div class="form-group" style="margin-bottom: 25px;">
              <label class="form-label">Email Address</label>
              <div class="input-wrapper">
                <i class="fas fa-envelope"></i>
                <input type="email" name="email" class="form-input" style="padding-left: 48px;" placeholder="Enter your email" required>
              </div>
            </div>

            <div class="form-group" style="margin-bottom: 25px;">
              <label class="form-label">Subject</label>
              <div class="input-wrapper">
                <i class="fas fa-tag"></i>
                <input type="text" name="subject" class="form-input" style="padding-left: 48px;" placeholder="How can we help?" required>
              </div>
            </div>

            <div class="form-group" style="margin-bottom: 25px;">
              <label class="form-label">Message</label>
              <textarea name="message" class="form-input" style="min-height: 150px; resize: vertical; padding: 18px;" placeholder="Type your message here..." required></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;" id="submitBtn">
              <i class="fas fa-paper-plane"></i> Send Message
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.style.opacity = '0.8';
    btn.style.pointerEvents = 'none';
    btn.innerHTML = '<div class="spinner" style="width: 20px; height: 20px; display: inline-block; margin-right: 10px; border-width: 2px;"></div> Sending...';

    // Simulate sending message
    setTimeout(() => {
      showToast('Message sent successfully! We will get back to you soon.', 'success');
      this.reset();
      btn.style.opacity = '1';
      btn.style.pointerEvents = 'auto';
      btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Message';
    }, 1500);
  });
</script>