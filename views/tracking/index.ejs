<div class="section">
  <div class="container">
    <div class="section-title">
      <h2>Track Your Order</h2>
      <p>Order #<%= order.orderNumber %></p>
    </div>

    <div class="grid grid-2" style="align-items: start;">
      <!-- Tracking Timeline -->
      <div class="glass" style="padding: 30px;">
        <h3 style="margin-bottom: 25px;"><i class="fas fa-route" style="color: var(--sage-green); margin-right: 10px;"></i> Order Status</h3>
        
        <div style="position: relative; padding-left: 30px;">
          <!-- Timeline Line -->
          <div style="position: absolute; left: 10px; top: 0; bottom: 0; width: 2px; background: var(--glass-border);"></div>
          
          <% allStatuses.forEach((status, index) => { 
            const isCompleted = index <= currentStatusIndex;
            const isCurrent = index === currentStatusIndex;
            const timelineEntry = timeline.find(t => t.status === status);
          %>
            <div style="position: relative; margin-bottom: 30px;">
              <!-- Dot -->
              <div style="
                position: absolute;
                left: -26px;
                top: 0;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: <%= isCompleted ? 'var(--sage-green)' : 'var(--glass-border)' %>;
                border: 3px solid <%= isCompleted ? 'var(--sage-green)' : 'var(--glass-border)' %>;
                <%= isCurrent ? 'box-shadow: 0 0 0 4px rgba(122, 158, 126, 0.3);' : '' %>
              "></div>
              
              <div style="
                padding: 15px;
                border-radius: 12px;
                background: <%= isCurrent ? 'rgba(122, 158, 126, 0.1)' : 'transparent' %>;
              ">
                <div style="font-weight: 600; margin-bottom: 5px;"><%= status %></div>
                <% if (timelineEntry) { %>
                  <div style="font-size: 12px; color: rgba(245, 240, 232, 0.6);">
                    <i class="fas fa-clock"></i> <%= new Date(timelineEntry.time).toLocaleString() %>
                  </div>
                  <% if (timelineEntry.note) { %>
                    <div style="font-size: 13px; color: rgba(245, 240, 232, 0.8); margin-top: 8px; padding: 8px; background: rgba(0,0,0,0.2); border-radius: 6px;">
                      <%= timelineEntry.note %>
                    </div>
                  <% } %>
                <% } else { %>
                  <div style="font-size: 12px; color: rgba(245, 240, 232, 0.4);">Pending</div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Order Details -->
      <div>
        <div class="glass" style="padding: 30px; margin-bottom: 20px;">
          <h3 style="margin-bottom: 20px;"><i class="fas fa-receipt" style="color: var(--sage-green); margin-right: 10px;"></i> Order Details</h3>
          
          <div style="margin-bottom: 20px;">
            <div style="font-size: 12px; color: rgba(245, 240, 232, 0.5); margin-bottom: 5px;">Order Number</div>
            <div style="font-weight: 600;"><%= order.orderNumber %></div>
          </div>

          <div style="margin-bottom: 20px;">
            <div style="font-size: 12px; color: rgba(245, 240, 232, 0.5); margin-bottom: 5px;">Order Date</div>
            <div><%= new Date(order.createdAt).toLocaleString() %></div>
          </div>

          <div style="margin-bottom: 20px;">
            <div style="font-size: 12px; color: rgba(245, 240, 232, 0.5); margin-bottom: 5px;">Total Amount</div>
            <div style="font-size: 24px; font-weight: 700; color: var(--sage-green);">KSH <%= order.finalAmount.toLocaleString() %></div>
          </div>

          <div style="margin-bottom: 20px;">
            <div style="font-size: 12px; color: rgba(245, 240, 232, 0.5); margin-bottom: 5px;">Delivery Address</div>
            <div><%= order.deliveryData.building %></div>
            <div style="color: rgba(245, 240, 232, 0.7);"><%= order.deliveryData.landmark %></div>
          </div>

          <div>
            <div style="font-size: 12px; color: rgba(245, 240, 232, 0.5); margin-bottom: 5px;">Contact Phone</div>
            <div><%= order.deliveryData.receiverPhone %></div>
          </div>
        </div>

        <!-- Items -->
        <div class="glass" style="padding: 30px; margin-bottom: 20px;">
          <h3 style="margin-bottom: 20px;"><i class="fas fa-box" style="color: var(--sage-green); margin-right: 10px;"></i> Items</h3>
          
          <% order.items.forEach(item => { %>
            <div style="display: flex; gap: 15px; padding: 15px 0; border-bottom: 1px solid var(--glass-border);">
              <img src="<%= item.image %>" alt="<%= item.name %>" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
              <div style="flex: 1;">
                <div style="font-weight: 600;"><%= item.name %></div>
                <div style="font-size: 13px; color: rgba(245, 240, 232, 0.6);">Qty: <%= item.quantity %></div>
              </div>
              <div style="font-weight: 600;">KSH <%= (item.price * item.quantity).toLocaleString() %></div>
            </div>
          <% }) %>
        </div>

        <!-- Suggestions -->
        <% if (suggestions.length > 0) { %>
          <div class="glass" style="padding: 30px;">
            <h3 style="margin-bottom: 20px;"><i class="fas fa-lightbulb" style="color: var(--sage-green); margin-right: 10px;"></i> You Might Also Like</h3>
            
            <div class="grid grid-2">
              <% suggestions.forEach(product => { %>
                <div class="product-card" onclick="openProductModal('<%= product._id %>')">
                  <img src="<%= product.images[0] %>" alt="<%= product.name %>" class="product-image" style="height: 120px;">
                  <div class="product-info" style="padding: 15px;">
                    <div class="product-name" style="font-size: 14px;"><%= product.name %></div>
                    <div class="product-price" style="font-size: 16px;">KSH <%= product.price.toLocaleString() %></div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Product Modal -->
<div class="modal-overlay" id="productModal">
  <div class="modal-content glass" style="max-width: 800px; width: 90%; padding: 0; overflow: hidden;">
    <div id="modalContent"></div>
  </div>
</div>

<script>
  async function openProductModal(productId) {
    try {
      const response = await fetch(`/shop/product/${productId}`);
      const product = await response.json();

      const modal = document.getElementById('productModal');
      const content = document.getElementById('modalContent');

      content.innerHTML = `
        <div style="display: grid; grid-template-columns: 1fr 1fr;">
          <div style="background: rgba(0,0,0,0.2);">
            <img src="${product.images[0]}" alt="${product.name}" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
          <div style="padding: 40px; position: relative;">
            <button onclick="closeProductModal()" style="position: absolute; top: 15px; right: 15px; background: none; border: none; color: var(--cream); font-size: 24px; cursor: pointer;">
              <i class="fas fa-times"></i>
            </button>
            <div class="product-category">${product.category}</div>
            <h2 style="margin-bottom: 15px;">${product.name}</h2>
            <div class="product-price" style="font-size: 24px; margin-bottom: 20px;">KSH ${product.price.toLocaleString()}</div>
            <p style="color: rgba(245, 240, 232, 0.8); margin-bottom: 30px; line-height: 1.8;">${product.description}</p>
            <button class="btn btn-primary btn-lg" onclick="addToCart('${product._id}'); closeProductModal();" style="width: 100%;">
              <i class="fas fa-shopping-cart"></i> Add to Cart
            </button>
          </div>
        </div>
      `;

      modal.classList.add('active');
    } catch (error) {
      console.error('Failed to load product:', error);
      showToast('Failed to load product details', 'error');
    }
  }

  function closeProductModal() {
    document.getElementById('productModal').classList.remove('active');
  }

  document.getElementById('productModal').addEventListener('click', (e) => {
    if (e.target.id === 'productModal') {
      closeProductModal();
    }
  });
</script>
