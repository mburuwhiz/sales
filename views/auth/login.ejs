<style>
  .auth-wrapper {
    display: flex;
    min-height: 80vh;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .auth-container {
    display: flex;
    width: 100%;
    max-width: 900px;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(122, 158, 126, 0.1);
  }

  .auth-visual {
    flex: 1;
    background: linear-gradient(135deg, rgba(45, 90, 39, 0.4), rgba(122, 158, 126, 0.2));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    position: relative;
    border-right: 1px solid var(--glass-border);
  }

  /* Peekaboo Bear */
  .bear-container {
    width: 200px;
    height: 200px;
    position: relative;
    margin-bottom: 30px;
  }

  .bear {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 0.3s ease;
  }

  .bear-head {
    width: 140px;
    height: 120px;
    background: #8b5a2b; /* Brown bear color */
    border-radius: 50% 50% 45% 45%;
    position: absolute;
    top: 40px;
    left: 30px;
    z-index: 2;
  }

  .bear-ear {
    width: 45px;
    height: 45px;
    background: #8b5a2b;
    border-radius: 50%;
    position: absolute;
    top: 25px;
    z-index: 1;
  }
  .bear-ear.left { left: 25px; }
  .bear-ear.right { right: 25px; }

  .bear-ear-inner {
    width: 25px;
    height: 25px;
    background: #d2b48c;
    border-radius: 50%;
    position: absolute;
    top: 10px;
    left: 10px;
  }

  .bear-eye {
    width: 16px;
    height: 16px;
    background: #333;
    border-radius: 50%;
    position: absolute;
    top: 50px;
    transition: all 0.2s ease;
  }
  .bear-eye.left { left: 40px; }
  .bear-eye.right { right: 40px; }

  .bear-eye-pupil {
    width: 6px;
    height: 6px;
    background: white;
    border-radius: 50%;
    position: absolute;
    top: 3px;
    left: 3px;
    transition: all 0.1s ease;
  }

  .bear-snout {
    width: 60px;
    height: 45px;
    background: #d2b48c;
    border-radius: 40%;
    position: absolute;
    bottom: 15px;
    left: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bear-nose {
    width: 22px;
    height: 14px;
    background: #333;
    border-radius: 50% 50% 50% 50% / 30% 30% 70% 70%;
    margin-top: 8px;
  }

  .bear-mouth {
    width: 20px;
    height: 10px;
    border-bottom: 2px solid #333;
    border-radius: 50%;
    margin-top: 2px;
  }

  .bear-paw {
    width: 45px;
    height: 45px;
    background: #8b5a2b;
    border-radius: 50%;
    position: absolute;
    bottom: -15px;
    z-index: 3;
    transition: all 0.3s ease;
  }
  .bear-paw.left { left: 40px; }
  .bear-paw.right { right: 40px; }

  /* Covering eyes state */
  .bear.covering-eyes .bear-paw.left {
    transform: translate(15px, -85px) rotate(20deg);
  }
  .bear.covering-eyes .bear-paw.right {
    transform: translate(-15px, -85px) rotate(-20deg);
  }
  .bear.covering-eyes .bear-eye {
    height: 4px;
    margin-top: 6px;
    border-radius: 2px;
  }
  .bear.covering-eyes .bear-eye-pupil { display: none; }

  /* Peeking state */
  .bear.peeking .bear-paw.left {
    transform: translate(15px, -85px) rotate(20deg);
  }
  .bear.peeking .bear-paw.right {
    transform: translate(-5px, -20px) rotate(-10deg);
  }
  .bear.peeking .bear-eye.left {
    height: 4px;
    margin-top: 6px;
    border-radius: 2px;
  }
  .bear.peeking .bear-eye.left .bear-eye-pupil { display: none; }


  .auth-form-wrapper {
    flex: 1;
    padding: 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 35px;
  }

  .auth-header h2 {
    font-size: 32px;
    margin-bottom: 8px;
  }

  .auth-header p {
    color: rgba(245, 240, 232, 0.7);
    font-size: 15px;
  }

  .input-wrapper {
    position: relative;
  }

  .input-wrapper i {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--sage-green);
    font-size: 16px;
  }

  .form-input.with-icon {
    padding-left: 48px;
  }

  .password-toggle {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    color: var(--sage-green);
    transition: color 0.3s;
  }

  .password-toggle:hover {
    color: var(--cream);
  }

  @media (max-width: 768px) {
    .auth-container {
      flex-direction: column;
    }
    .auth-visual {
      display: none; /* Hide visual on small screens for better UX */
    }
    .auth-form-wrapper {
      padding: 30px 20px;
    }
  }
</style>

<div class="section">
  <div class="container auth-wrapper">
    <div class="auth-container">

      <!-- Interactive Visual Left Side -->
      <div class="auth-visual">
        <div class="bear-container">
          <div class="bear" id="interactiveBear">
            <div class="bear-ear left"><div class="bear-ear-inner"></div></div>
            <div class="bear-ear right"><div class="bear-ear-inner"></div></div>
            <div class="bear-head">
              <div class="bear-eye left"><div class="bear-eye-pupil"></div></div>
              <div class="bear-eye right"><div class="bear-eye-pupil"></div></div>
              <div class="bear-snout">
                <div class="bear-nose"></div>
                <div class="bear-mouth"></div>
              </div>
            </div>
            <div class="bear-paw left"></div>
            <div class="bear-paw right"></div>
          </div>
        </div>
        <h3 style="margin-bottom: 10px; font-family: 'Playfair Display', serif;">Fresh Harvest</h3>
        <p style="text-align: center; color: rgba(245, 240, 232, 0.8); font-size: 14px;">Welcome back to your organic food hub.</p>
      </div>

      <!-- Login Form Right Side -->
      <div class="auth-form-wrapper">
        <div class="auth-header">
          <h2>Welcome Back</h2>
          <p>Sign in to your account</p>
        </div>

        <% if (error) { %>
          <div class="toast error" style="margin-bottom: 20px; animation: none; position: relative; top: 0; right: 0; box-shadow: none;">
            <i class="fas fa-exclamation-circle"></i> <%= error %>
          </div>
        <% } %>

        <form action="/auth/login" method="POST" id="loginForm">
          <div class="form-group">
            <label class="form-label">Email Address</label>
            <div class="input-wrapper">
              <i class="fas fa-envelope"></i>
              <input type="email" name="email" id="emailInput" class="form-input with-icon" placeholder="Enter your email" required autofocus>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Password</label>
            <div class="input-wrapper">
              <i class="fas fa-lock"></i>
              <input type="password" name="password" id="passwordInput" class="form-input with-icon" placeholder="Enter your password" required>
              <i class="fas fa-eye password-toggle" id="togglePassword"></i>
            </div>
          </div>

          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px;">
              <input type="checkbox" style="accent-color: var(--sage-green);">
              Remember me
            </label>
            <a href="#" style="font-size: 13px; color: var(--sage-green); text-decoration: none; transition: color 0.2s;">Forgot password?</a>
          </div>

          <button type="submit" class="btn btn-primary" id="submitBtn" style="width: 100%; margin-bottom: 25px; padding: 16px; font-size: 16px;">
            <i class="fas fa-sign-in-alt"></i> Sign In
          </button>
        </form>

        <div style="text-align: center; padding-top: 25px; border-top: 1px solid var(--glass-border);">
          <p style="color: rgba(245, 240, 232, 0.7); font-size: 14px;">
            Don't have an account? 
            <a href="/auth/register" style="color: var(--sage-green); font-weight: 600; text-decoration: none;">Sign up here</a>
          </p>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const emailInput = document.getElementById('emailInput');
  const passwordInput = document.getElementById('passwordInput');
  const togglePassword = document.getElementById('togglePassword');
  const bear = document.getElementById('interactiveBear');
  const pupils = document.querySelectorAll('.bear-eye-pupil');
  const visualArea = document.querySelector('.auth-visual');

  // Eye tracking logic
  document.addEventListener('mousemove', (e) => {
    // Only track if bear is not covering eyes
    if (bear.classList.contains('covering-eyes')) return;

    if (!visualArea) return;
    const rect = visualArea.getBoundingClientRect();

    // Only track if mouse is somewhat near the visual area
    const mouseX = e.clientX;
    const mouseY = e.clientY;

    pupils.forEach(pupil => {
      // Simple offset calculation
      const x = (mouseX - (rect.left + rect.width / 2)) / 30;
      const y = (mouseY - (rect.top + rect.height / 2)) / 30;

      // Constrain movement
      const moveX = Math.max(-3, Math.min(3, x));
      const moveY = Math.max(-3, Math.min(3, y));

      pupil.style.transform = `translate(${moveX}px, ${moveY}px)`;
    });
  });

  // Bear covers eyes when focusing on password
  passwordInput.addEventListener('focus', () => {
    if (passwordInput.type === 'password') {
      bear.classList.add('covering-eyes');
      bear.classList.remove('peeking');
    } else {
      bear.classList.remove('covering-eyes');
      bear.classList.add('peeking');
    }
  });

  passwordInput.addEventListener('blur', () => {
    bear.classList.remove('covering-eyes');
    bear.classList.remove('peeking');
    // Reset pupils
    pupils.forEach(pupil => {
      pupil.style.transform = `translate(0px, 0px)`;
    });
  });

  // Toggle password visibility and bear state
  togglePassword.addEventListener('click', function () {
    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordInput.setAttribute('type', type);
    this.classList.toggle('fa-eye-slash');

    // Update bear state if password input is focused
    if (document.activeElement === passwordInput) {
      if (type === 'text') {
        bear.classList.remove('covering-eyes');
        bear.classList.add('peeking');
      } else {
        bear.classList.add('covering-eyes');
        bear.classList.remove('peeking');
      }
    }
  });

  // Form submit state
  document.getElementById('loginForm').addEventListener('submit', function(e) {
    const btn = document.getElementById('submitBtn');
    btn.style.opacity = '0.8';
    btn.style.pointerEvents = 'none';
    btn.innerHTML = '<div class="spinner" style="width: 20px; height: 20px; display: inline-block; margin-right: 10px; border-width: 2px;"></div> Signing in...';
  });
</script>