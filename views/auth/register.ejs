<style>
  .auth-wrapper {
    display: flex;
    min-height: 80vh;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .auth-container {
    display: flex;
    width: 100%;
    max-width: 1000px;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(122, 158, 126, 0.1);
  }

  .auth-visual {
    flex: 1;
    background: linear-gradient(135deg, rgba(45, 90, 39, 0.4), rgba(122, 158, 126, 0.2));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    position: relative;
    border-right: 1px solid var(--glass-border);
  }

  /* Peekaboo Bear styles - shared with login */
  .bear-container {
    width: 200px;
    height: 200px;
    position: relative;
    margin-bottom: 30px;
  }

  .bear {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 0.3s ease;
  }

  .bear-head {
    width: 140px;
    height: 120px;
    background: #8b5a2b; /* Brown bear color */
    border-radius: 50% 50% 45% 45%;
    position: absolute;
    top: 40px;
    left: 30px;
    z-index: 2;
  }

  .bear-ear {
    width: 45px;
    height: 45px;
    background: #8b5a2b;
    border-radius: 50%;
    position: absolute;
    top: 25px;
    z-index: 1;
  }
  .bear-ear.left { left: 25px; }
  .bear-ear.right { right: 25px; }

  .bear-ear-inner {
    width: 25px;
    height: 25px;
    background: #d2b48c;
    border-radius: 50%;
    position: absolute;
    top: 10px;
    left: 10px;
  }

  .bear-eye {
    width: 16px;
    height: 16px;
    background: #333;
    border-radius: 50%;
    position: absolute;
    top: 50px;
    transition: all 0.2s ease;
  }
  .bear-eye.left { left: 40px; }
  .bear-eye.right { right: 40px; }

  .bear-eye-pupil {
    width: 6px;
    height: 6px;
    background: white;
    border-radius: 50%;
    position: absolute;
    top: 3px;
    left: 3px;
    transition: all 0.1s ease;
  }

  .bear-snout {
    width: 60px;
    height: 45px;
    background: #d2b48c;
    border-radius: 40%;
    position: absolute;
    bottom: 15px;
    left: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bear-nose {
    width: 22px;
    height: 14px;
    background: #333;
    border-radius: 50% 50% 50% 50% / 30% 30% 70% 70%;
    margin-top: 8px;
  }

  .bear-mouth {
    width: 20px;
    height: 10px;
    border-bottom: 2px solid #333;
    border-radius: 50%;
    margin-top: 2px;
  }

  .bear-paw {
    width: 45px;
    height: 45px;
    background: #8b5a2b;
    border-radius: 50%;
    position: absolute;
    bottom: -15px;
    z-index: 3;
    transition: all 0.3s ease;
  }
  .bear-paw.left { left: 40px; }
  .bear-paw.right { right: 40px; }

  /* Covering eyes state */
  .bear.covering-eyes .bear-paw.left {
    transform: translate(15px, -85px) rotate(20deg);
  }
  .bear.covering-eyes .bear-paw.right {
    transform: translate(-15px, -85px) rotate(-20deg);
  }
  .bear.covering-eyes .bear-eye {
    height: 4px;
    margin-top: 6px;
    border-radius: 2px;
  }
  .bear.covering-eyes .bear-eye-pupil { display: none; }

  /* Peeking state */
  .bear.peeking .bear-paw.left {
    transform: translate(15px, -85px) rotate(20deg);
  }
  .bear.peeking .bear-paw.right {
    transform: translate(-5px, -20px) rotate(-10deg);
  }
  .bear.peeking .bear-eye.left {
    height: 4px;
    margin-top: 6px;
    border-radius: 2px;
  }
  .bear.peeking .bear-eye.left .bear-eye-pupil { display: none; }


  .auth-form-wrapper {
    flex: 1.2;
    padding: 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-height: 85vh;
    overflow-y: auto;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 35px;
  }

  .auth-header h2 {
    font-size: 32px;
    margin-bottom: 8px;
  }

  .auth-header p {
    color: rgba(245, 240, 232, 0.7);
    font-size: 15px;
  }

  .input-wrapper {
    position: relative;
  }

  .input-wrapper i {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--sage-green);
    font-size: 16px;
  }

  .form-input.with-icon {
    padding-left: 48px;
  }

  .password-toggle {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    color: var(--sage-green);
    transition: color 0.3s;
  }

  .password-toggle:hover {
    color: var(--cream);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media (max-width: 900px) {
    .auth-container {
      flex-direction: column;
    }
    .auth-visual {
      display: none;
    }
    .auth-form-wrapper {
      padding: 30px 20px;
    }
  }

  @media (max-width: 600px) {
    .form-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
</style>

<div class="section">
  <div class="container auth-wrapper">
    <div class="auth-container">

      <!-- Interactive Visual Left Side -->
      <div class="auth-visual">
        <div class="bear-container">
          <div class="bear" id="interactiveBear">
            <div class="bear-ear left"><div class="bear-ear-inner"></div></div>
            <div class="bear-ear right"><div class="bear-ear-inner"></div></div>
            <div class="bear-head">
              <div class="bear-eye left"><div class="bear-eye-pupil"></div></div>
              <div class="bear-eye right"><div class="bear-eye-pupil"></div></div>
              <div class="bear-snout">
                <div class="bear-nose"></div>
                <div class="bear-mouth"></div>
              </div>
            </div>
            <div class="bear-paw left"></div>
            <div class="bear-paw right"></div>
          </div>
        </div>
        <h3 style="margin-bottom: 10px; font-family: 'Playfair Display', serif;">Join the Harvest</h3>
        <p style="text-align: center; color: rgba(245, 240, 232, 0.8); font-size: 14px; max-width: 250px;">Sign up today to get farm-fresh produce delivered straight to your door.</p>
      </div>

      <!-- Registration Form Right Side -->
      <div class="auth-form-wrapper">
        <div class="auth-header">
          <h2>Create Account</h2>
          <p>Start your organic journey</p>
        </div>

        <% if (error) { %>
          <div class="toast error" style="margin-bottom: 20px; animation: none; position: relative; top: 0; right: 0; box-shadow: none;">
            <i class="fas fa-exclamation-circle"></i> <%= error %>
          </div>
        <% } %>

        <form action="/auth/register" method="POST" id="registerForm">

          <div class="form-group">
            <label class="form-label">Full Name</label>
            <div class="input-wrapper">
              <i class="fas fa-user"></i>
              <input type="text" name="name" class="form-input with-icon" placeholder="Enter your full name" required autofocus>
            </div>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Email Address</label>
              <div class="input-wrapper">
                <i class="fas fa-envelope"></i>
                <input type="email" name="email" class="form-input with-icon" placeholder="Enter your email" required>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Phone Number</label>
              <div class="input-wrapper">
                <i class="fas fa-phone-alt"></i>
                <input type="tel" name="phone" class="form-input with-icon" placeholder="e.g., 0712345678" required>
              </div>
            </div>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Password</label>
              <div class="input-wrapper">
                <i class="fas fa-lock"></i>
                <input type="password" name="password" id="passwordInput" class="form-input with-icon" placeholder="Create a password (min 6 chars)" minlength="6" required>
                <i class="fas fa-eye password-toggle" id="togglePassword"></i>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Confirm Password</label>
              <div class="input-wrapper">
                <i class="fas fa-lock"></i>
                <input type="password" name="confirmPassword" id="confirmPasswordInput" class="form-input with-icon" placeholder="Confirm your password" required>
              </div>
            </div>
          </div>

          <div style="margin-bottom: 25px;">
            <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; font-size: 13px; color: rgba(245, 240, 232, 0.7);">
              <input type="checkbox" required style="margin-top: 3px; accent-color: var(--sage-green);">
              <span>I agree to the <a href="/policies" style="color: var(--sage-green); text-decoration: none;">Terms of Service</a> and <a href="/policies" style="color: var(--sage-green); text-decoration: none;">Privacy Policy</a></span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary" id="submitBtn" style="width: 100%; margin-bottom: 25px; padding: 16px; font-size: 16px;">
            <i class="fas fa-user-plus"></i> Create Account
          </button>
        </form>

        <div style="text-align: center; padding-top: 25px; border-top: 1px solid var(--glass-border);">
          <p style="color: rgba(245, 240, 232, 0.7); font-size: 14px;">
            Already have an account? 
            <a href="/auth/login" style="color: var(--sage-green); font-weight: 600; text-decoration: none;">Sign in here</a>
          </p>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const passwordInput = document.getElementById('passwordInput');
  const confirmPasswordInput = document.getElementById('confirmPasswordInput');
  const togglePassword = document.getElementById('togglePassword');
  const bear = document.getElementById('interactiveBear');
  const pupils = document.querySelectorAll('.bear-eye-pupil');
  const visualArea = document.querySelector('.auth-visual');

  // Eye tracking logic
  document.addEventListener('mousemove', (e) => {
    // Only track if bear is not covering eyes
    if (bear.classList.contains('covering-eyes')) return;

    if (!visualArea) return;
    const rect = visualArea.getBoundingClientRect();

    // Only track if mouse is somewhat near the visual area
    const mouseX = e.clientX;
    const mouseY = e.clientY;

    pupils.forEach(pupil => {
      // Simple offset calculation
      const x = (mouseX - (rect.left + rect.width / 2)) / 30;
      const y = (mouseY - (rect.top + rect.height / 2)) / 30;

      // Constrain movement
      const moveX = Math.max(-3, Math.min(3, x));
      const moveY = Math.max(-3, Math.min(3, y));

      pupil.style.transform = `translate(${moveX}px, ${moveY}px)`;
    });
  });

  // Bear covers eyes when focusing on password fields
  function handlePasswordFocus() {
    if (passwordInput.type === 'password') {
      bear.classList.add('covering-eyes');
      bear.classList.remove('peeking');
    } else {
      bear.classList.remove('covering-eyes');
      bear.classList.add('peeking');
    }
  }

  function handlePasswordBlur() {
    // Only remove covering eyes if focus isn't moving to another password field
    setTimeout(() => {
      if (document.activeElement !== passwordInput && document.activeElement !== confirmPasswordInput) {
        bear.classList.remove('covering-eyes');
        bear.classList.remove('peeking');
        // Reset pupils
        pupils.forEach(pupil => {
          pupil.style.transform = `translate(0px, 0px)`;
        });
      }
    }, 10);
  }

  passwordInput.addEventListener('focus', handlePasswordFocus);
  confirmPasswordInput.addEventListener('focus', handlePasswordFocus);

  passwordInput.addEventListener('blur', handlePasswordBlur);
  confirmPasswordInput.addEventListener('blur', handlePasswordBlur);

  // Toggle password visibility and bear state
  togglePassword.addEventListener('click', function () {
    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordInput.setAttribute('type', type);
    // Link confirm password type to master password field visibility
    confirmPasswordInput.setAttribute('type', type);

    this.classList.toggle('fa-eye-slash');

    // Update bear state if password input is focused
    if (document.activeElement === passwordInput || document.activeElement === confirmPasswordInput) {
      if (type === 'text') {
        bear.classList.remove('covering-eyes');
        bear.classList.add('peeking');
      } else {
        bear.classList.add('covering-eyes');
        bear.classList.remove('peeking');
      }
    }
  });

  // Form submit state
  document.getElementById('registerForm').addEventListener('submit', function(e) {
    const btn = document.getElementById('submitBtn');
    btn.style.opacity = '0.8';
    btn.style.pointerEvents = 'none';
    btn.innerHTML = '<div class="spinner" style="width: 20px; height: 20px; display: inline-block; margin-right: 10px; border-width: 2px;"></div> Creating Account...';
  });
</script>