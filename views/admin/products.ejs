<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
  <style>
    .admin-sidebar {
      position: fixed;
      left: 0;
      top: 0;
      width: 260px;
      height: 100vh;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(10px);
      border-right: 1px solid var(--glass-border);
      z-index: 100;
      overflow-y: auto;
    }

    .admin-sidebar-header {
      padding: 20px;
      border-bottom: 1px solid var(--glass-border);
    }

    .admin-sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--cream);
      text-decoration: none;
    }

    .admin-nav {
      list-style: none;
      padding: 15px 0;
    }

    .admin-nav li a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      color: rgba(245, 240, 232, 0.8);
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .admin-nav li a:hover,
    .admin-nav li a.active {
      background: rgba(122, 158, 126, 0.2);
      color: var(--cream);
    }

    .admin-main {
      margin-left: 260px;
      padding: 30px;
      min-height: 100vh;
    }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
    }

    .admin-table th,
    .admin-table td {
      padding: 15px;
      text-align: left;
      border-bottom: 1px solid var(--glass-border);
    }

    .admin-table th {
      font-weight: 600;
      color: rgba(245, 240, 232, 0.8);
    }

    .product-thumb {
      width: 50px;
      height: 50px;
      object-fit: cover;
      border-radius: 8px;
    }

    .cropper-container {
      max-height: 400px;
    }

    @media (max-width: 768px) {
      .admin-sidebar { transform: translateX(-100%); }
      .admin-sidebar.active { transform: translateX(0); }
      .admin-main { margin-left: 0; }
    }
  </style>
</head>
<body>
  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <a href="/admin" class="admin-sidebar-logo">
        <img src="/logo.png" alt="Fresh Harvest">
        <span style="font-weight: 700;">ADMIN</span>
      </a>
    </div>
    <ul class="admin-nav">
      <li><a href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
      <li><a href="/admin/products" class="active"><i class="fas fa-box"></i> Products</a></li>
      <li><a href="/admin/orders"><i class="fas fa-shopping-cart"></i> Orders</a></li>
      <li><a href="/admin/emails"><i class="fas fa-envelope"></i> Email Broadcast</a></li>
      <li><a href="/admin/help-requests"><i class="fas fa-question-circle"></i> Help Requests</a></li>
      <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
      <li><a href="/admin/settings/whatsapp"><i class="fab fa-whatsapp"></i> WhatsApp</a></li>
      <li style="margin-top: 20px; border-top: 1px solid var(--glass-border); padding-top: 15px;">
        <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </li>
    </ul>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
      <div>
        <h2>Products</h2>
        <p style="color: rgba(245, 240, 232, 0.6);">Manage your product catalog</p>
      </div>
      <a href="/admin/products/add" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add Product
      </a>
    </div>

    <!-- Filter -->
    <div class="glass" style="padding: 15px; margin-bottom: 20px;">
      <form action="/admin/products" method="GET" style="display: flex; gap: 15px; flex-wrap: wrap;">
        <select name="category" class="form-input" style="width: auto;" onchange="this.form.submit()">
          <option value="">All Categories</option>
          <option value="Vegetables" <%= selectedCategory === 'Vegetables' ? 'selected' : '' %>>Vegetables</option>
          <option value="Fruits" <%= selectedCategory === 'Fruits' ? 'selected' : '' %>>Fruits</option>
          <option value="Cereals" <%= selectedCategory === 'Cereals' ? 'selected' : '' %>>Cereals</option>
          <option value="Dairy & Eggs" <%= selectedCategory === 'Dairy & Eggs' ? 'selected' : '' %>>Dairy & Eggs</option>
          <option value="Spices" <%= selectedCategory === 'Spices' ? 'selected' : '' %>>Spices</option>
        </select>
      </form>
    </div>

    <!-- Products Table -->
    <div class="glass" style="padding: 25px;">
      <div style="overflow-x: auto;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Category</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(product => { %>
              <tr>
                <td>
                  <% if (product.images && product.images.length > 0) { %>
                    <img src="<%= product.images[0] %>" alt="<%= product.name %>" class="product-thumb">
                  <% } else { %>
                    <div style="width: 50px; height: 50px; background: rgba(255,255,255,0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                      <i class="fas fa-image" style="color: rgba(245, 240, 232, 0.3);"></i>
                    </div>
                  <% } %>
                </td>
                <td><%= product.name %></td>
                <td><span class="badge badge-info"><%= product.category %></span></td>
                <td>KSH <%= product.price.toLocaleString() %></td>
                <td><%= product.stockQty %></td>
                <td>
                  <div style="display: flex; gap: 8px;">
                    <a href="/admin/products/edit/<%= product._id %>" class="btn btn-primary btn-sm">
                      <i class="fas fa-edit"></i>
                    </a>
                    <form action="/admin/products/delete/<%= product._id %>" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this product?');">
                      <button type="submit" class="btn btn-secondary btn-sm" style="background: rgba(139, 38, 53, 0.3); border-color: #8b2635;">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div style="display: flex; justify-content: center; gap: 10px; margin-top: 20px;">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/admin/products?category=<%= selectedCategory %>&page=<%= i %>" 
               class="btn <%= currentPage === i ? 'btn-primary' : 'btn-secondary' %> btn-sm"
               style="min-width: 40px;">
              <%= i %>
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>
