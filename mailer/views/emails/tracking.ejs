<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Update - <%= orderId %></title>
  <style>
    body { 
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
      line-height: 1.6; 
      color: #333; 
      max-width: 600px; 
      margin: 0 auto; 
      padding: 20px;
      background-color: #f5f0e8;
    }
    .header { 
      background: linear-gradient(135deg, #1a3d1c, #2d5a27); 
      padding: 30px; 
      text-align: center;
      border-radius: 12px 12px 0 0;
    }
    .header h1 { 
      color: #7a9e7e; 
      margin: 0;
      font-size: 28px;
    }
    .content { 
      background: #ffffff; 
      padding: 40px 30px;
      border-radius: 0 0 12px 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    .status-box {
      background: linear-gradient(135deg, #2d5a27, #4a7c44);
      color: white;
      padding: 25px;
      border-radius: 12px;
      text-align: center;
      margin: 25px 0;
    }
    .status-box h3 {
      margin: 0;
      font-size: 24px;
    }
    .btn { 
      display: inline-block; 
      padding: 14px 32px; 
      background: linear-gradient(135deg, #2d5a27, #4a7c44); 
      color: #ffffff; 
      text-decoration: none; 
      border-radius: 8px;
      font-weight: 600;
      margin: 20px 0;
    }
    .footer { 
      text-align: center; 
      padding: 30px; 
      color: #666; 
      font-size: 13px;
    }
    .note {
      background: #f9f9f9;
      padding: 15px;
      border-radius: 8px;
      border-left: 4px solid #2d5a27;
      margin: 20px 0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>🌿 FRESH HARVEST</h1>
  </div>
  
  <div class="content">
    <h2 style="color: #1a3d1c; margin-top: 0;">Order Update</h2>
    
    <p>Hi <%= name %>,</p>
    
    <p>There's an update on your order:</p>
    
    <div class="status-box">
      <div style="font-size: 14px; opacity: 0.9; margin-bottom: 10px;">Order #<%= orderId %></div>
      <h3><%= status %></h3>
    </div>
    
    <% if (note) { %>
      <div class="note">
        <strong>Note:</strong> <%= note %>
      </div>
    <% } %>
    
    <div style="text-align: center;">
      <a href="<%= trackingLink %>" class="btn">Track Your Order</a>
    </div>
    
    <p style="margin-top: 30px;">We'll keep you updated on your order's progress!</p>
  </div>
  
  <div class="footer">
    <p><strong>Fresh Harvest Grocery</strong></p>
    <p>Nairobi, Kenya | orders@freshharvest.app | 0113 323 234</p>
    <p style="margin-top: 15px; font-size: 12px; color: #999;">
      Questions? Reply to this email or contact our support team.
    </p>
  </div>
</body>
</html>
